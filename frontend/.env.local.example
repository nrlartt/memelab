# Split-stack dev (Next on :3000, FastAPI on :8000):
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Docker / Railway single image: use empty at build so the browser posts to same-origin
# ``/api/*`` (Next rewrites or app/api proxy → uvicorn). If unset at build, the
# client also defaults to same-origin, but setting it explicitly avoids mistakes.
# NEXT_PUBLIC_API_BASE=

# Public GitHub repo (footer). Override only if you fork. Default: nrlartt/memelab
NEXT_PUBLIC_GITHUB_URL=https://github.com/nrlartt/memelab
