# ─── Database ───────────────────────────────────────────────────────────
POSTGRES_USER=memedna
POSTGRES_PASSWORD=memedna
POSTGRES_DB=memedna
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://memedna:memedna@postgres:5432/memedna

# ─── Chat LLM (OpenAI-compatible: OpenAI, Groq, Together, Fireworks…) ───
# Default: Groq + OpenAI's open-weight gpt-oss-120b reasoning model.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_CHAT_MODEL=openai/gpt-oss-120b
OPENAI_REASONING_EFFORT=low

# ─── Embeddings (Groq has no embeddings; use OpenAI or leave blank) ─────
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Bitquery ───────────────────────────────────────────────────────────
# https://graphql.bitquery.io/
BITQUERY_API_KEY=
BITQUERY_ENDPOINT=https://streaming.bitquery.io/eap

# ─── BNB Smart Chain ────────────────────────────────────────────────────
# For live ingest the public endpoint is fine (it serves the last ~18h
# of logs). For full-history backfill (scripts/backfill_fourmeme.py) you
# need a paid archive-enabled RPC and must set BSC_RPC_ARCHIVE=true.
#   * QuickNode  https://quicknode.com/chains/bsc
#   * Alchemy    https://alchemy.com/chain/bnb
#   * Ankr Pro   https://www.ankr.com/rpc/advanced-api/
# Primary (public) JSON-RPC. When it errors or times out, the app can switch
# to BSC_RPC_FALLBACK_URL if set (e.g. Alchemy) without a restart.
BSC_RPC_URL=https://bsc-dataseed.bnbchain.org
# Full BNB mainnet URL including path (never commit real keys; set in Railway/secret only).
# Example: https://bnb-mainnet.g.alchemy.com/v2/<your_api_key>
BSC_RPC_FALLBACK_URL=
BSC_CHAIN_ID=56
BSC_RPC_ARCHIVE=false
# Retention window of the RPC when NOT in archive mode (blocks). Public
# nodes ~48k (~18h). Only bumped when you know the provider's retention.
BSC_RPC_SAFE_HISTORY_BLOCKS=48000
# Upper bound for a single eth_getLogs range. Public ~4k, premium 10k.
BSC_RPC_MAX_BLOCK_RANGE=4000
# Four.Meme TokenManager2 on BSC
FOURMEME_TOKEN_MANAGER=0x5c952063c7fc8610FFDB798152D69F0B9550762b
FOURMEME_FACTORY_DEPLOY_BLOCK=38500000

# Used only for on-chain event anchoring (registry contract)
MEMEDNA_REGISTRY_ADDRESS=
MEMEDNA_DEPLOYER_PRIVATE_KEY=

# ─── Web research ───────────────────────────────────────────────────────
# Fallback chain:  X (Twitter) → Tavily → SerpAPI → Jina → DuckDuckGo (free)
# DuckDuckGo is 100% keyless and always-on, so references always populate.
# Add the paid ones for richer timelines / higher-quality external snippets.
SERPAPI_API_KEY=
TAVILY_API_KEY=
JINA_API_KEY=

# ─── BscScan (for holder counts) ────────────────────────────────────────
# Free key: https://bscscan.com/myapikey  (100k req/day, 5 req/s).
# Without it, holder counts stay at 0 (everything else still works).
BSCSCAN_API_KEY=

# ─── X (Twitter) cookie-auth scraping (OPTIONAL) ────────────────────────
# Enable this to let MemeDNA pull the *actual tweets* that spawned a meme
# wave. Boosts source_center extraction dramatically.
#   1. Create a DEDICATED alt X account (do NOT use your main one).
#   2. Log into x.com in a browser.
#   3. DevTools → Application → Cookies → https://x.com
#   4. Copy the values of `auth_token` and `ct0` into the variables below.
# Cookies expire every ~30 days; refresh them when the research log
# starts showing "X search auth failed".
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ─── Pipeline tuning ────────────────────────────────────────────────────
PIPELINE_LOOKBACK_HOURS=720
PIPELINE_INCREMENTAL=true
# Last N BSC blocks (newest-first) merged into every ingest; 0 = cursor/Bitquery only.
INGEST_HEAD_BLOCKS=6000
PIPELINE_MIN_CLUSTER_SIZE=2
PIPELINE_MIN_CONFIDENCE=0.25
PIPELINE_CLUSTER_EPS=0.28
PIPELINE_MAX_TOKENS_PER_RUN=60000
# Max blocks per incremental tick when the cursor is far behind (0 = unlimited, not recommended).
PIPELINE_INCREMENTAL_MAX_BLOCKS=12000
PIPELINE_MAX_CLUSTERS_PER_RUN=140
PIPELINE_BATCH_SIZE=256
PIPELINE_INTERVAL_MINUTES=5

# ─── API ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*
# Keep 0 in production: the API runs a background job that ingests new Four.Meme
# tokens and runs the LLM pipeline. Set to 1 only if you use a *separate*
# process (e.g. `python -m memedna.pipeline.scheduler` or a second container)
# and want to avoid duplicate timers on the same host.
MEMEDNA_DISABLE_SCHEDULER=0
# Shared secret for internal/admin routes (X-Admin-Token header). You invent
# this string yourself — it is not issued by any provider. Used by
# POST /internal/ingest/quick, POST /internal/pipeline/run, etc.
MEMEDNA_ADMIN_TOKEN=changeme

# ─── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
